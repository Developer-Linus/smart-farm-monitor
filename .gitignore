# =============================================================================
# Smart Farm Monitor — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Virtual environment
backend/venv/
venv/
.venv/
env/
ENV/

# Type checking / linting
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
backend/farm.db
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# AI model files (large binaries — store in cloud storage or Git LFS)
# -----------------------------------------------------------------------------
model/saved_model/best_model.h5
model/saved_model/*.tflite
model/dataset/

# Jupyter / TensorBoard
*.ipynb_checkpoints/
logs/
runs/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
node_modules/

# Vite build output
frontend/dist/

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# Local env files
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
.env
*.pem
*.key
secrets.json
credentials.json

# -----------------------------------------------------------------------------
# Arduino build output
# -----------------------------------------------------------------------------
esp32/**/.cache/
esp32/**/build/
